DB_TYPE=postgres
# Set only in Render dashboard (Environment) — Internal Database URL, never commit real values.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE_NAME

NODE_ENV=production
# Browser origins allowed to call the API (dashboard app, public landing / waitlist, etc.)
ALLOWED_ORIGINS=https://your-frontend-url.onrender.com,https://your-landing-site.com
TIME_ZONE=UTC

# Render sets PORT automatically; no need to set it here
